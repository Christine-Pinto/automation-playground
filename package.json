{
  "name": "automation-playground",
  "version": "1.0.0",
  "description": "A public playground for practicing UI, API, and contract test automation as a community.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:pact": "npm run test:pact:consumer && npm run test:pact:verify",
    "test:pact:consumer": "jest tests/pact-practice/consumer",
    "test:pact:verify": "ts-node tests/pact-practice/provider/verify.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.1.1",
    "@pact-foundation/pact": "^17.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
